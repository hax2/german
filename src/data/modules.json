          "heißen": "are called",
          "Sie": "you (formal)"
        }
      },
      {
        "id": "m2-s12",
        "german": "Ich heiße Thomas.",
        "english": "My name is Thomas. (I am called Thomas.)",
        "wordMeanings": {
