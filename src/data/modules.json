  {
    "id": "module-8",
    "title": "Chapter 8: Modal Verbs",
    "description": "Modal verbs (können, müssen, wollen) express ability, necessity, or desire. The second verb goes to the very end of the sentence.",
    "level": "Advanced",
    "sentences": [
      {
        "id": "m8-s1",
        "german": "Ich kann schwimmen.",
        "english": "I can swim.",
        "wordMeanings": {
          "Ich": "I",
          "kann": "can",
          "schwimmen": "swim"
        }
      },
      {
        "id": "m8-s2",
        "german": "Kannst du mir helfen?",
