  {
    "id": "module-3",
    "title": "Chapter 3: Nouns & Genders (Nominative)",
    "description": "German has three genders: masculine (der), feminine (die), and neuter (das). Learn to use them in the basic nominative case.",
    "level": "Beginner",
    "sentences": [
      {
        "id": "m3-s1",
        "german": "Der Mann ist groß.",
        "english": "The man is tall.",
        "wordMeanings": {
          "Der": "the (masculine)",
          "Mann": "man",
          "ist": "is",
          "groß": "tall / big"
        }
      },
      {
        "id": "m3-s2",
        "german": "Die Frau ist klein.",
        "english": "The woman is small.",
        "wordMeanings": {
