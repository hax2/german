  {
    "id": "module-2",
    "title": "Chapter 2: Introductions & Pronouns",
    "description": "Learn to introduce yourself and use basic personal pronouns with the verb 'sein' (to be).",
    "level": "Beginner",
    "sentences": [
      {
        "id": "m2-s1",
        "german": "Ich bin Anna.",
        "english": "I am Anna.",
        "wordMeanings": {
          "Ich": "I",
          "bin": "am",
          "Anna": "Anna"
        }
      },
      {
        "id": "m2-s2",
        "german": "Bist du Frank?",
        "english": "Are you Frank?",
        "wordMeanings": {
          "Bist": "are",
          "du": "you (singular, informal)",
          "Frank": "Frank"
        }
      },
      {
        "id": "m2-s3",
        "german": "Ja, ich bin Frank.",
        "english": "Yes, I am Frank.",
        "wordMeanings": {
          "Ja": "yes",
          "ich": "I",
          "bin": "am",
          "Frank": "Frank"
        }
      },
      {
        "id": "m2-s4",
        "german": "Wer bist du?",
        "english": "Who are you?",
        "wordMeanings": {
          "Wer": "who",
          "bist": "are",
          "du": "you"
