      },
      {
        "id": "m3-s6",
        "german": "Ein Kind spielt.",
        "english": "A child is playing.",
        "wordMeanings": {
          "Ein": "a (neuter)",
          "Kind": "child",
          "spielt": "plays / is playing"
        }
      },
      {
        "id": "m3-s7",
        "german": "Ist der Apfel gut?",
        "english": "Is the apple good?",
        "wordMeanings": {
          "Ist": "is",
          "der": "the (masc)",
          "Apfel": "apple",
          "gut": "good"
