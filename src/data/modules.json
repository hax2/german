          "ist": "is",
          "kalt": "cold"
        }
      },
      {
        "id": "m2-s8",
        "german": "Wir sind Freunde.",
        "english": "We are friends.",
        "wordMeanings": {
          "Wir": "we",
          "sind": "are",
          "Freunde": "friends"
