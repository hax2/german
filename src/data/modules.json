        "german": "Die Katze ist schön.",
        "english": "The cat is beautiful.",
        "wordMeanings": {
          "Die": "the (fem)",
          "Katze": "cat",
          "ist": "is",
          "schön": "beautiful"
        }
      },
      {
        "id": "m3-s10",
        "german": "Das Auto ist neu.",
        "english": "The car is new.",
        "wordMeanings": {
          "Das": "the (neuter)",
          "Auto": "car",
          "ist": "is",
          "neu": "new"
        }
      }
    ]
  },
  {
    "id": "module-4",
    "title": "Chapter 4: The Accusative Case",
    "description": "The direct object requires the accusative case. Notice how 'der' changes to 'den', but 'die' and 'das' stay the same.",
    "level": "Intermediate",
    "sentences": [
      {
        "id": "m4-s1",
        "german": "Ich habe den Apfel.",
        "english": "I have the apple.",
        "wordMeanings": {
          "Ich": "I",
          "habe": "have",
          "den": "the (masculine accusative)",
          "Apfel": "apple"
        }
      },
      {
        "id": "m4-s2",
        "german": "Hast du einen Hund?",
        "english": "Do you have a dog?",
        "wordMeanings": {
          "Hast": "have",
          "du": "you",
          "einen": "a (masculine accusative)",
          "Hund": "dog"
        }
      },
      {
        "id": "m4-s3",
        "german": "Ich sehe die Frau.",
        "english": "I see the woman.",
        "wordMeanings": {
          "Ich": "I",
          "sehe": "see",
          "die": "the (feminine accusative)",
          "Frau": "woman"
        }
      },
      {
        "id": "m4-s4",
        "german": "Er kauft das Auto.",
        "english": "He buys the car.",
        "wordMeanings": {
          "Er": "he",
          "kauft": "buys",
          "das": "the (neuter accusative)",
          "Auto": "car"
        }
      },
      {
        "id": "m4-s5",
        "german": "Wir brauchen einen Tisch.",
        "english": "We need a table.",
        "wordMeanings": {
          "Wir": "we",
          "brauchen": "need",
          "einen": "a (masculine accusative)",
          "Tisch": "table"
        }
      },
      {
        "id": "m4-s6",
        "german": "Ich trinke den Kaffee.",
        "english": "I drink the coffee.",
        "wordMeanings": {
          "Ich": "I",
          "trinke": "drink",
          "den": "the (masculine accusative)",
          "Kaffee": "coffee"
        }
      },
      {
        "id": "m4-s7",
        "german": "Sie isst einen Apfel.",
        "english": "She is eating an apple.",
        "wordMeanings": {
          "Sie": "she",
          "isst": "eats",
          "einen": "an (masculine accusative)",
          "Apfel": "apple"
        }
      },
      {
        "id": "m4-s8",
        "german": "Liest du das Buch?",
        "english": "Are you reading the book?",
        "wordMeanings": {
          "Liest": "read",
          "du": "you",
          "das": "the (neuter accusative)",
          "Buch": "book"
        }
      },
      {
        "id": "m4-s9",
        "german": "Ich liebe dich.",
        "english": "I love you.",
        "wordMeanings": {
          "Ich": "I",
          "liebe": "love",
          "dich": "you (accusative)"
        }
      },
      {
        "id": "m4-s10",
        "german": "Er fragt mich.",
        "english": "He asks me.",
        "wordMeanings": {
          "Er": "he",
          "fragt": "asks",
          "mich": "me (accusative)"
        }
      }
