          "Frau": "woman",
          "ist": "is",
          "klein": "small"
        }
      },
      {
        "id": "m3-s3",
        "german": "Das Kind ist hier.",
        "english": "The child is here.",
        "wordMeanings": {
          "Das": "the (neuter)",
          "Kind": "child",
          "ist": "is",
          "hier": "here"
        }
      },
      {
        "id": "m3-s4",
        "german": "Ein Mann kommt.",
        "english": "A man is coming.",
        "wordMeanings": {
